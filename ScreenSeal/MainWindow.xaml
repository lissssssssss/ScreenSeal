<Window x:Class="ScreenSeal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="屏谧 ScreenSeal"
        Height="0" Width="0"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Visibility="Hidden">
    <tb:TaskbarIcon x:Name="TrayIcon"
                    ToolTipText="屏谧 ScreenSeal"
                    TrayMouseDoubleClick="OnTrayDoubleClick">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem Header="选择应用..." Click="OnSelectApps"/>
                <MenuItem Header="开启 IM 精准遮挡" Click="OnTogglePrecise"/>
                <MenuItem Header="自定义区域遮挡" Click="OnCustomRegion"/>
                <MenuItem Header="全屏模糊遮挡" Click="OnFullScreenBlur"/>
                <Separator/>
                <MenuItem Header="关闭全部遮挡" Click="OnUnlockAll"/>
                <MenuItem Header="设置..." Click="OnSettings"/>
                <MenuItem x:Name="StartupMenuItem" Header="开机自启" IsCheckable="True" Click="OnToggleStartup"/>
                <Separator/>
                <MenuItem Header="退出" Click="OnExit"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>
</Window>
