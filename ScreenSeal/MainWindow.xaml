<Window x:Class="ScreenSeal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="屏谧 ScreenSeal"
        Height="480" Width="420"
        MinHeight="400" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True">
    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="屏谧 ScreenSeal"
                        TrayMouseDoubleClick="OnTrayDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="OnShowMainWindow"/>
                    <MenuItem Header="开启 IM 精准遮挡" Click="OnTogglePrecise"/>
                    <MenuItem Header="自定义区域遮挡" Click="OnCustomRegion"/>
                    <MenuItem Header="全屏模糊遮挡" Click="OnFullScreenBlur"/>
                    <Separator/>
                    <MenuItem Header="关闭全部遮挡" Click="OnUnlockAll"/>
                    <MenuItem Header="设置..." Click="OnSettings"/>
                    <MenuItem x:Name="StartupMenuItem" Header="开机自启" IsCheckable="True" Click="OnToggleStartup"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="OnExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="屏谧 ScreenSeal" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,16" TextWrapping="Wrap" Foreground="#555"
                   Text="选择需要遮挡隐私信息的应用。开启「精准遮挡」后，仅对已勾选的应用窗口生效。"/>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="AppListPanel"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="全选" Padding="12,4" Click="OnSelectAll"/>
            <Button Content="全不选" Padding="12,4" Margin="8,0,0,0" Click="OnSelectNone"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Foreground="#888" TextWrapping="Wrap"
                       Text="关闭窗口后程序仍在托盘运行。"/>
            <Button Grid.Column="1" Content="开启精准遮挡" Padding="16,6" Margin="0,0,8,0"
                    Click="OnStartPreciseMask"/>
            <Button Grid.Column="2" Content="保存" Padding="24,6" IsDefault="True"
                    Click="OnSaveSelection"/>
        </Grid>
    </Grid>
</Grid>
</Window>
