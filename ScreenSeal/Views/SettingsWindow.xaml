<Window x:Class="ScreenSeal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏谧 ScreenSeal - 设置"
        Height="620" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="屏谧 ScreenSeal" FontSize="20" FontWeight="SemiBold"/>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 全局热键 -->
                <TextBlock Text="全局热键" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="精准 IM 遮挡"/>
                    <TextBox x:Name="HotkeyPrecise" Grid.Column="1"
                             IsReadOnly="True" Focusable="True"
                             Background="#F5F5F5" Cursor="Hand"
                             PreviewKeyDown="Hotkey_PreviewKeyDown"
                             GotFocus="Hotkey_GotFocus"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="自定义区域遮挡"/>
                    <TextBox x:Name="HotkeyCustom" Grid.Column="1"
                             IsReadOnly="True" Focusable="True"
                             Background="#F5F5F5" Cursor="Hand"
                             PreviewKeyDown="Hotkey_PreviewKeyDown"
                             GotFocus="Hotkey_GotFocus"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="解锁全部"/>
                    <TextBox x:Name="HotkeyUnlock" Grid.Column="1"
                             IsReadOnly="True" Focusable="True"
                             Background="#F5F5F5" Cursor="Hand"
                             PreviewKeyDown="Hotkey_PreviewKeyDown"
                             GotFocus="Hotkey_GotFocus"/>
                </Grid>

                <!-- 遮挡样式 -->
                <TextBlock Text="遮挡样式" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <ComboBox x:Name="MaskStyleCombo" SelectedIndex="0">
                    <ComboBoxItem Content="纯色黑"/>
                    <ComboBoxItem Content="磨砂模糊"/>
                </ComboBox>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock VerticalAlignment="Center" Text="不透明度"/>
                    <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1" Width="200" Margin="12,0"/>
                    <TextBlock x:Name="OpacityLabel" VerticalAlignment="Center" Width="40"/>
                </StackPanel>

                <CheckBox x:Name="StartupCheck" Content="开机自启" Margin="0,16,0,0"/>

                <!-- 高级 -->
                <Border Height="1" Background="#E0E0E0" Margin="0,16,0,8"/>
                <TextBlock Text="高级" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="窗口检测间隔"/>
                    <TextBox x:Name="PollIntervalBox" Grid.Column="1" Text="1500"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#666" Text="毫秒 (200–10000)"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="空闲时检测间隔"/>
                    <TextBox x:Name="IdlePollIntervalBox" Grid.Column="1" Text="3000"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#666" Text="毫秒 (500–30000)"/>
                </Grid>

                <TextBlock Text="自定义进程名（每行一个）" Margin="0,12,0,4"/>
                <TextBox x:Name="CustomProcessBox" Height="60" AcceptsReturn="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="自定义窗口标题关键词（每行一个）" Margin="0,8,0,4"/>
                <TextBox x:Name="CustomTitleBox" Height="60" AcceptsReturn="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Margin="0,16,0,4" TextWrapping="Wrap" Foreground="#666"
                           Text="默认热键：Ctrl+Shift+Q / W / E。托盘图标右键可快速操作。"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="80" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="保存" Width="80" IsDefault="True" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
